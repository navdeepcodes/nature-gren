o%2Fstorage%2Fv1%2Fobject%2Fpublic%2Fhero%2F1784561798400.png&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fqyfntagbyxvfxjnkbarr.supabase.co%2Fstorage%2Fv1%2Fobject%2Fpublic%2Fhero%2F1784561798400.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fqyfntagbyxvfxjnkbarr.supabase.co%2Fstorage%2Fv1%2Fobject%2Fpublic%2Fhero%2F1784561798400.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fqyfntagbyxvfxjnkbarr.supabase.co%2Fstorage%2Fv1%2Fobject%2Fpublic%2Fhero%2F1784561798400.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fqyfntagbyxvfxjnkbarr.supabase.co%2Fstorage%2Fv1%2Fobject%2Fpublic%2Fhero%2F1784561798400.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fqyfntagbyxvfxjnkbarr.supabase.co%2Fstorage%2Fv1%2Fobject%2Fpublic%2Fhero%2F1784561798400.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fqyfntagbyxvfxjnkbarr.supabase.co%2Fstorage%2Fv1%2Fobject%2Fpublic%2Fhero%2F1784561798400.png&amp;w=3840&amp;q=75\"/></div><div><span class=\"text-sm font-semibold uppercase tracking-[0.24em] text-[var(--primary)]\">Our Journey</span><h2 class=\"mt-5 font-serif text-5xl leading-tight text-[var(--text)] whitespace-pre-line\"></h2><p class=\"mt-8 text-lg leading-8 text-[var(--text-muted)] whitespace-pre-line\"></p></div></div></div></section><section class=\"relative overflow-hidden bg-[#FCFAF7] py-28 lg:py-36\"><div class=\"absolute inset-0\"><div class=\"absolute left-0 top-0 h-[500px] w-[500px] rounded-full bg-[#F3F7EF] blur-[140px]\"></div><div class=\"absolute right-0 bottom-0 h-[420px] w-[420px] rounded-full bg-[#F6F2EA] blur-[120px]\"></div></div><div class=\"\n        mx-auto\n        w-full\n        max-w-[1320px]\n        px-5\n        lg:px-8\n        \n      \"><div class=\"relative grid items-center gap-24 lg:grid-cols-[0.9fr_1.1fr]\"><div style=\"opacity:0;transform:translateY(40px)\"><span class=\"inline-flex rounded-full bg-[#EDF5E9] px-5 py-2 text-sm font-semibold uppercase tracking-[0.22em] text-[#426239]\">Why Jute</span><h2 class=\"mt-8 max-w-xl font-serif text-5xl leading-[1.08] text-[var(--text)] lg:text-6xl\">Sustainability<br/>Starts With<br/>Better Materials.</h2><p class=\"mt-8 max-w-xl text-lg leading-9 text-[var(--text-muted)]\">NatureGren carefully selects premium natural jute because it combines timeless beauty, exceptional durability and genuine environmental responsibility in every handcrafted product.</p><div class=\"mt-14 space-y-10\"><div class=\"flex gap-6\" style=\"opacity:0;transform:translateX(-20px)\"><div class=\"mt-2 h-3 w-3 rounded-full bg-[#2E4B2C]\"></div><div><h3 class=\"text-xl font-semibold text-[var(--text)]\">100% Natural Fiber</h3><p class=\"mt-3 max-w-lg leading-8 text-[var(--text-muted)]\">Jute is a biodegradable plant fiber that naturally returns to the earth without polluting it.</p></div></div><div class=\"flex gap-6\" style=\"opacity:0;transform:translateX(-20px)\"><div class=\"mt-2 h-3 w-3 rounded-full bg-[#2E4B2C]\"></div><div><h3 class=\"text-xl font-semibold text-[var(--text)]\">Reusable &amp; Durable</h3><p class=\"mt-3 max-w-lg leading-8 text-[var(--text-muted)]\">Designed to last for years, reducing the need for disposable plastic alternatives.</p></div></div><div class=\"flex gap-6\" style=\"opacity:0;transform:translateX(-20px)\"><div class=\"mt-2 h-3 w-3 rounded-full bg-[#2E4B2C]\"></div><div><h3 class=\"text-xl font-semibold text-[var(--text)]\">Low Environmental Impact</h3><p class=\"mt-3 max-w-lg leading-8 text-[var(--text-muted)]\">Jute cultivation requires significantly less water and chemicals than synthetic materials.</p></div></div><div class=\"flex gap-6\" style=\"opacity:0;transform:translateX(-20px)\"><div class=\"mt-2 h-3 w-3 rounded-full bg-[#2E4B2C]\"></div><div><h3 class=\"text-xl font-semibold text-[var(--text)]\">Supports Artisan Communities</h3><p class=\"mt-3 max-w-lg leading-8 text-[var(--text-muted)]\">Every handcrafted product contributes to preserving traditional craftsmanship and local livelihoods.</p></div></div></div></div><div style=\"opacity:0;transform:translateX(40px)\"><div class=\"relative flex min-h-[720px] items-center justify-center\"><div class=\"absolute inset-0 flex items-center justify-center\"><div class=\"h-[520px] w-[520px] rounded-full bg-[#EDF5E9] blur-[120px]\"></div></div><div class=\"absolute h-[560px] w-[560px] rounded-full border border-[#E8E2D8]\"></div><div class=\"absolute h-[420px] w-[420px] rounded-full border border-dashed border-[#D9D0C1]\"></div><div class=\"relative z-20\" style=\"opacity:0;transform:scale(0.9)\"><div class=\"rounded-[40px] bg-white p-10 shadow-[0_30px_80px_rgba(0,0,0,0.12)]\"><div class=\"flex items-center justify-center\"><div class=\"flex h-20 w-20 items-center justify-center rounded-full bg-[#2E4B2C] text-white\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf\" aria-hidden=\"true\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg></div></div><p class=\"mt-8 text-center text-sm uppercase tracking-[0.35em] text-[#56734D]\">Premium Material</p><h2 class=\"mt-3 text-center font-serif text-6xl text-[#1F2B1D]\">100%</h2><p class=\"mt-4 text-center text-xl font-medium\">Natural Jute</p><div class=\"mt-10 flex items-center justify-center gap-3 rounded-full bg-[#F7F4EF] px-5 py-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check text-[#2E4B2C]\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg>Sustainable • Renewable • Durable</div></div></div><div class=\"absolute -left-2 top-8 z-30\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"w-60 rounded-[30px] border border-[#ECE7DE] bg-white p-6 shadow-xl\"><div class=\"flex items-start justify-between\"><div class=\"flex h-12 w-12 items-center justify-center rounded-2xl bg-[#EDF5E9]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf text-[#2E4B2C]\" aria-hidden=\"true\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg></div><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-up-right text-gray-300\" aria-hidden=\"true\"><path d=\"M7 7h10v10\"></path><path d=\"M7 17 17 7\"></path></svg></div><h3 class=\"mt-6 text-lg font-semibold\">100% Natural</h3><p class=\"mt-2 text-sm leading-7 text-gray-500\">Plant-based premium fibre</p></div></div><div class=\"absolute -right-2 top-24 z-30\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"w-60 rounded-[30px] border border-[#ECE7DE] bg-white p-6 shadow-xl\"><div class=\"flex items-start justify-between\"><div class=\"flex h-12 w-12 items-center justify-center rounded-2xl bg-[#EDF5E9]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-recycle text-[#2E4B2C]\" aria-hidden=\"true\"><path d=\"M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.